#!/usr/bin/env python3

import fcntl
import json
import os
import subprocess
import sys


SUBSCRIBE_EVENTS = ["window", "workspace"]


def sway_json(*args):
    return json.loads(subprocess.check_output(["swaymsg", *args]))


def focused_path(node, path=None):
    path = [] if path is None else path
    current = path + [node]

    if node.get("focused"):
        return current

    for child in node.get("nodes", []) + node.get("floating_nodes", []):
        found = focused_path(child, current)
        if found:
            return found

    return None


def output_for(path):
    for node in reversed(path):
        if node.get("type") == "output" and node.get("name") != "__i3":
            return node
    return None


def set_split():
    try:
        path = focused_path(sway_json("-t", "get_tree"))
    except (OSError, subprocess.CalledProcessError, json.JSONDecodeError):
        return

    if not path:
        return

    focused = path[-1]
    if focused.get("type") != "con" or focused.get("nodes"):
        return

    output = output_for(path)
    if not output:
        return

    win = focused.get("rect", {})
    out = output.get("rect", {})
    if not win.get("height") or not out.get("height"):
        return

    win_ratio = win["width"] / win["height"]
    out_ratio = out["width"] / out["height"]
    command = "splith" if win_ratio > out_ratio else "splitv"

    subprocess.run(["swaymsg", command], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def subscribe():
    process = subprocess.Popen(
        ["swaymsg", "-m", "-t", "subscribe", json.dumps(SUBSCRIBE_EVENTS)],
        stdout=subprocess.PIPE,
        text=True,
    )

    assert process.stdout is not None
    for line in process.stdout:
        if not line.strip():
            continue
        set_split()


if __name__ == "__main__":
    lock = open(os.path.expanduser("~/.cache/sway-autotile.lock"), "w")
    try:
        fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        sys.exit(0)

    set_split()
    try:
        subscribe()
    except KeyboardInterrupt:
        sys.exit(0)
